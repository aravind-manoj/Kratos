# LLM provider (optional — auto-detects when only one key is set)
# Priority when multiple keys: openai > anthropic > google > openrouter > groq
# LLM_PROVIDER=openai
# LLM_MAIN_MODEL=
# LLM_SUB_MODEL=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google AI Studio / Gemini
GOOGLE_API_KEY=
# GEMINI_API_KEY=

# OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_APP_NAME=Kratos

# Groq
GROQ_API_KEY=
